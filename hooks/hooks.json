{
  "description": "Greppable hooks — GDL lint validation",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-gdl-lint.sh",
            "async": false
          }
        ]
      }
    ]
  }
}
